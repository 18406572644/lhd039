{
  "name": "vintage-typewriter",
  "version": "1.0.0",
  "description": "复古打字机风格沉浸式写作桌面工具",
  "main": "electron/main.js",
  "author": "Typewriter",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build && electron-builder",
    "build:vite": "vite build",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "electron-builder"
  },
  "dependencies": {
    "@arco-design/web-vue": "^2.54.0",
    "vue": "^3.4.0",
    "pinia": "^2.1.7"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.typewriter.writer",
    "productName": "Vintage Typewriter",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    }
  }
}
